POSTGRES_DB=repopilot
POSTGRES_USER=repopilot
POSTGRES_PASSWORD=repopilot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=change-me-to-a-long-random-secret-change-me
GITHUB_TOKEN=
OPENAI_API_KEY=

# Optional GitHub publishing.
# Leave disabled for local DRAFT_READY branch/commit preparation only.
REPOPILOT_GITHUB_ENABLED=false
REPOPILOT_GITHUB_API_BASE_URL=https://api.github.com
REPOPILOT_GITHUB_TOKEN=

# Optional Docker sandbox runtime.
REPOPILOT_SANDBOX_IMAGE=maven:3.9-eclipse-temurin-17
REPOPILOT_SANDBOX_TIMEOUT_SECONDS=600
REPOPILOT_MAVEN_CACHE=../.m2
REPOPILOT_SANDBOX_DOCKER_CHECK_ENABLED=true

# Optional CoderAgent model provider.
# Leave disabled for deterministic local demo recipes and safe planning fallback.
REPOPILOT_CODER_MODE=disabled
REPOPILOT_CODER_API_BASE_URL=https://api.openai.com/v1
REPOPILOT_CODER_MODEL=
REPOPILOT_CODER_MAX_COMPLETION_TOKENS=4096
REPOPILOT_CODER_INSTRUCTION_ROLE=developer

BACKEND_PORT=8080
AGENT_WORKER_PORT=8090
FRONTEND_PORT=5173
